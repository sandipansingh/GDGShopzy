# GDGShopzy Environment Configuration
# For local non-Docker development, see app-specific .env.example files


# App Configuration
# [REQUIRED FOR: dev, prod, prod-shared]
APP_NAME=GDGShopzy
NODE_ENV=development  # Use 'production' for prod/prod-shared

# Client Configuration
# [REQUIRED FOR: dev, prod, prod-shared]
CLIENT_PORT=5173
# For dev/prod: Use http://localhost:4001/api/v1
# For prod-shared: Use your production API URL
VITE_API_BASE_URL=http://localhost:4001/api/v1

# Server Configuration
# [REQUIRED FOR: dev, prod, prod-shared]
# SERVER_PORT is the EXTERNAL port for Docker port mapping (e.g., 4001, 4001, 8080)
# Inside Docker containers, the server always listens on internal port 4001
# The compose files map ${SERVER_PORT}:4001 (external:internal)
SERVER_PORT=4001
# For dev/prod: Use http://localhost:4001
# For prod-shared: Use your production domain
PUBLIC_API_URL=http://localhost:4001
CLIENT_URL=http://localhost:5173
API_DOCS_ENABLED=true

# Database (PostgreSQL)
# [REQUIRED FOR: dev, prod]
# [NOT NEEDED FOR: prod-shared - use external DATABASE_URL instead]
# For dev/prod (Docker internal):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gdgshopzy_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gdgshopzy_db

# For prod-shared (external database):
# Uncomment and replace with your external database URL:
# DATABASE_URL=postgresql://user:password@external-db-host:5432/gdgshopzy_db

# Redis Configuration
# [REQUIRED FOR: dev, prod]
# [NOT NEEDED FOR: prod-shared - use external REDIS_URL instead]
# For dev/prod (Docker internal):
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_REQUIRED=false
REDIS_KEY_PREFIX=gdgshopzy:

# For prod-shared (external Redis):
# Uncomment and replace with your external Redis URL:
# REDIS_URL=redis://external-redis-host:6379
# REDIS_USERNAME=your_redis_user
# REDIS_PASSWORD=your_redis_password

# Cache TTL Settings (seconds)
# [REQUIRED FOR: dev, prod, prod-shared]
REDIS_CACHE_TTL_SECONDS=60
CACHE_TTL_PRODUCT_LIST_SECONDS=60
CACHE_TTL_PRODUCT_DETAIL_SECONDS=300
CACHE_TTL_SELLER_DASHBOARD_SECONDS=60
CACHE_TTL_CATEGORY_LIST_SECONDS=300

# MinIO (Object Storage)
# [REQUIRED FOR: dev, prod]
# [NOT NEEDED FOR: prod-shared - use external MinIO instead]
# For dev/prod (Docker internal):
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
MINIO_USE_SSL=false

# For prod-shared (external MinIO):
# Uncomment and replace with your external MinIO configuration:
# MINIO_ENDPOINT=external-minio-host
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=your_minio_access_key
# MINIO_SECRET_KEY=your_minio_secret_key
# MINIO_BUCKET=product-images
# MINIO_USE_SSL=true

# JWT Authentication
# [REQUIRED FOR: dev, prod, prod-shared]
JWT_ACCESS_SECRET=replace_me_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=replace_me_refresh_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=refreshToken

# CORS & Security
# [REQUIRED FOR: dev, prod, prod-shared]
# For dev: http://localhost:5173
# For prod/prod-shared: Add your production domain(s), comma-separated
CORS_ORIGINS=http://localhost:5173
CORS_CREDENTIALS=true
REQUEST_BODY_LIMIT=1mb
# Set to 'true' if behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY=false

# Rate Limiting
# [REQUIRED FOR: dev, prod, prod-shared]
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_RATE_LIMIT_MAX=5

# Email (Resend)
# [OPTIONAL FOR: dev, prod, prod-shared]
# Leave RESEND_API_KEY empty to disable email sending
RESEND_API_KEY=
EMAIL_FROM="GDGShopzy <noreply@example.com>"
EMAIL_REPLY_TO=support@example.com
# Set to 'true' to enable email sending
EMAIL_ENABLED=false

# Email Feature Flags
EMAIL_ORDER_NOTIFICATIONS_ENABLED=true
EMAIL_AUTH_NOTIFICATIONS_ENABLED=true
EMAIL_EMPLOYEE_INVITES_ENABLED=true
EMAIL_NOTIFY_EMPLOYEES_ON_NEW_ORDER=false
EMAIL_ORDER_STATUS_SELLER_CONFIRMATION_ENABLED=false

# Email Token Expiration
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30
EMPLOYEE_INVITE_EXPIRES_HOURS=48

# Shared Production Infrastructure
# [REQUIRED FOR: prod-shared ONLY]
# [NOT NEEDED FOR: dev, prod]
# External Docker network name for shared infrastructure
# Create with: docker network create shared_infra
SHARED_NETWORK=shared_infra
